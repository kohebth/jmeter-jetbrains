<idea-plugin>
    <id>com.github.kohebth.jmeterviewer</id>
    <name>JMeter Viewer</name>
    <vendor email="ncdduy@hotmail.com">kohebth</vendor>

    <description><![CDATA[
        Opens Apache JMeter test plans with JMeter's native editor inside JetBrains IDEs.<br/>
        Requires an official Apache JMeter 5.6.3 installation selected under
        Settings/Preferences &gt; Tools &gt; JMeter.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
                name="JMeter Test Plan"
                language="XML"
                implementationClass="com.github.kohebth.jmeterviewer.ide.JMeterFileType"
                fieldName="INSTANCE"
                extensions="jmx"/>
        <fileEditorProvider
                implementation="com.github.kohebth.jmeterviewer.ide.JMeterFileEditorProvider"/>
        <applicationService
                serviceImplementation="com.github.kohebth.jmeterviewer.runtime.JMeterRuntimeService"/>
        <applicationService
                serviceImplementation="com.github.kohebth.jmeterviewer.runtime.JMeterSettings"/>
        <applicationService
                serviceImplementation="com.github.kohebth.jmeterviewer.editor.JMeterWorkspaceService"/>
        <projectService
                serviceImplementation="com.github.kohebth.jmeterviewer.toolwindow.JMeterToolWindowController"/>
        <toolWindow
                id="JMeter"
                anchor="bottom"
                icon="/icons/jmeter-feather.gif"
                factoryClass="com.github.kohebth.jmeterviewer.toolwindow.JMeterToolWindowFactory"/>
        <applicationConfigurable
                id="jmeter.viewer.settings"
                parentId="tools"
                displayName="JMeter"
                instance="com.github.kohebth.jmeterviewer.ide.JMeterSettingsConfigurable"/>
        <fileDocumentSynchronizationVetoer
                implementation="com.github.kohebth.jmeterviewer.editor.JMeterDocumentSynchronizationVetoer"/>
        <fileDocumentManagerListener
                implementation="com.github.kohebth.jmeterviewer.editor.JMeterFileDocumentListener"/>
    </extensions>
</idea-plugin>
